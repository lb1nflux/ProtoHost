spring:
  datasource:
    url: jdbc:mysql://localhost:3306/protohost?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: YOUR_DB_USERNAME
    password: YOUR_DB_PASSWORD
    driver-class-name: com.mysql.cj.jdbc.Driver
  servlet:
    multipart:
      max-file-size: 200MB
      max-request-size: 200MB

mybatis-plus:
  configuration:
    map-underscore-to-camel-case: true
  global-config:
    db-config:
      logic-delete-field: deleted
      logic-delete-value: 1
      logic-not-delete-value: 0

app:
  jwt:
    secret: "YOUR_JWT_SECRET_BASE64"   # 生成方式: openssl rand -base64 32
    expiration: 604800                  # 7天（秒）
    view-expiration: 7200               # 2小时（秒）
  upload:
    base-path: ./uploads

server:
  port: 8080
